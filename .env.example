# .env.example — Copy to .env and fill in values

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/reflexrush"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
HOST="0.0.0.0"

